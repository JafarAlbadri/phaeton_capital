{
  "compilerOptions": {
    "lib": ["ESNext"],
    "target": "ESNext",
    "module": "ESNext",
    "moduleDetection": "force",
    "moduleResolution": "bundler",
    "resolveJsonModule": true,
    "esModuleInterop": true,
    "noEmit": true,
    "strict": true,
    "types": ["bun"],
    "skipLibCheck": true,
    "noFallthroughCasesInSwitch": true
  },
  "include": ["src/**/*.ts", "scripts/**/*.ts", "*.ts"]
}
