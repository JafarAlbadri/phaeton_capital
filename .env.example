# Environment Configuration

# Gemini API is required for the Sentiment classification AI to function
GEMINI_API_KEY=your_gemini_api_key_here

# Used internally by Docker Compose (Leave as-is unless manually changed in compose file)
DATABASE_URL=postgresql://sentiment_user:sentiment_password@postgres:5432/sentiment_db?schema=public

# Optional: Reddit Credentials if scaling past unauthenticated limits
REDDIT_CLIENT_ID=
REDDIT_CLIENT_SECRET=

# AI Model settings
AI_MODEL=gemini-2.5-flash
AI_RPM_LIMIT=4

# Target keyword/ticker to scrape and analyze (e.g. NVDA, Gold, wallstreetbets)
TARGET_KEYWORD= Gold
