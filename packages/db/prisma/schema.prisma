generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Sentiment {
  id               String   @id @default(cuid())
  ticker           String
  sentiment        Float
  is_manipulation  Boolean
  confidence       Float
  author           String
  author_karma     Int
  account_age_days Int
  post_timestamp   DateTime
  content          String
  duplicate_hash   String   @unique
  createdAt        DateTime @default(now())
}

model FundamentalData {
  ticker          String   @id
  current_price   Float?
  target_price    Float?
  recommendation  String?
  pe_ratio        Float?
  high_52_week    Float?
  low_52_week     Float?
  market_cap      BigInt?
  volume          BigInt?
  updatedAt       DateTime @updatedAt
}

model FinancialHistory {
  id                String   @id @default(cuid())
  ticker            String
  year              Int
  eps               Float?
  revenue_per_share Float?
  roe               Float?
  net_debt_ebitda   Float?
  pe_ratio          Float?
  ps_ratio          Float?
  pb_ratio          Float?
  ev_ebit           Float?

  @@unique([ticker, year])
  @@index([ticker])
}

model InsiderTrade {
  id            String   @id @default(cuid())
  ticker        String
  insider_name  String
  position      String?
  transaction   String
  shares        Int
  value         Float
  date          DateTime

  @@index([ticker, date(sort: Desc)])
}

